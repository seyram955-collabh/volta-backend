# ─────────────────────────────────────────────
#  Volta Lake Emergency Backend — Environment
#  Copy this file to .env and fill in your keys
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Africa's Talking SMS (https://africastalking.com)
# Use "sandbox" as username for testing
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key_here

# Emergency phone numbers (Ghana format: +233XXXXXXXXX)
PHONE_SOS=+233241111111
PHONE_FIRE=+233242222222
PHONE_MEDICAL=+233243333333
PHONE_SINKING=+233244444444

# Optional: A master alert number that receives ALL alert types
PHONE_MASTER=+233200000000

# Frontend URL (for CORS — your HTML app's domain)
FRONTEND_URL=http://localhost:5500

# Database file path (SQLite — auto-created on first run)
DB_PATH=./db/alerts.db
